# ReWritter runtime environment variables for docker compose
# Replace with your real key before testing chat/vendor connectivity.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# 高德地图配置（需要申请API密钥）
AMAP_API_KEY=your_amap_api_key_here
AMAP_BASE_URL=https://restapi.amap.com/v3
AMAP_CACHE_TTL=86400

# 小红书发布配置（需要填写真实账号）
XIAOHONGSHU_USERNAME=your_xiaohongshu_username
XIAOHONGSHU_PASSWORD=your_xiaohongshu_password
XIAOHONGSHU_HEADLESS=true
XIAOHONGSHU_TIMEOUT=30000

# Playwright配置
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=true

# RAG混合检索配置
RAG_HYBRID_ALPHA=0.6
ENABLE_HYBRID_SEARCH=true

# Optional overrides
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat
# DEEPSEEK_REASONER_MODEL=deepseek-reasoner
# MONGODB_URI=mongodb://mongodb:27017
# MONGODB_DB=rewritter